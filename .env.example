# App
EXPO_PUBLIC_APP_NAME=SyncTracker
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_APP_VERSION=1.0.0
EXPO_PUBLIC_ENABLE_LOGS=true

# API
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/api
EXPO_PUBLIC_API_TIMEOUT=15000

# Realtime
EXPO_PUBLIC_SOCKET_URL=http://localhost:3000
EXPO_PUBLIC_SOCKET_RECONNECT=true
EXPO_PUBLIC_SOCKET_TIMEOUT=10000

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=public-key

# Auth
EXPO_PUBLIC_AUTH_TOKEN_STORAGE_KEY=sync_tracker_token
EXPO_PUBLIC_REFRESH_TOKEN_STORAGE_KEY=sync_tracker_refresh

# Monitoring
EXPO_PUBLIC_SENTRY_DSN=https://xxxx@sentry.io/xxxx
EXPO_PUBLIC_SENTRY_ENVIRONMENT=development

# Graph Engine
EXPO_PUBLIC_GRAPH_MAX_NODES=50
EXPO_PUBLIC_GRAPH_ANIMATION_SPEED=300

# Features
EXPO_PUBLIC_ENABLE_GRAPH_VIEW=true
EXPO_PUBLIC_ENABLE_TREE_VIEW=true
EXPO_PUBLIC_ENABLE_REALTIME=true
